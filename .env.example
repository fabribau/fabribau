# .env.example

# Nota:
# - En desarrollo local con Astro dev: usa .env
# - En Cloudflare Workers:
#   - PUBLIC_* (no secretas) van en wrangler.jsonc -> vars
#   - El resto van como secrets con: wrangler secret put <KEY>

# Google AI (Ask About Me)
GOOGLE_GENERATIVE_AI_API_KEY="APIKEY"

# Resend (formulario de contacto)
RESEND_API_KEY="APIKEY"
RESEND_FROM_EMAIL="Nombre <email@tudominio.com>"

# Email de contacto destino
CONTACT_EMAIL="email@gmail.com"

# Cloudflare Turnstile
# Obtené tus claves en: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY="CLAVE_SECRETA"
PUBLIC_TURNSTILE_SITE_KEY="CLAVE_PUBLICA"

# Para desarrollo local usá las claves de prueba de Cloudflare:
# PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA  (siempre pasa)
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA  (siempre válido)