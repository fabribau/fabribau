---
import BaseLayout from './BaseLayout.astro';
import StatusBadge from '../components/projects/StatusBadge.astro';
import TechTag from '../components/projects/TechTag.astro';
import { formatDate } from '../lib/content';

interface Props {
  title: string;
  description: string;
  status: 'completed' | 'in-progress' | 'archived';
  stack: string[];
  githubUrl?: string;
  demoUrl?: string;
  startDate: Date;
  endDate?: Date;
}

const { title, description, status, stack, githubUrl, demoUrl, startDate, endDate } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="project-detail container-prose">
    <header class="project-header animate-fade-up">
      <div class="project-meta">
        <StatusBadge status={status} />
        <span class="project-dates">
          {formatDate(startDate)}{endDate ? ` — ${formatDate(endDate)}` : ' — Presente'}
        </span>
      </div>
      <h1 class="project-title">{title}</h1>
      <p class="project-description">{description}</p>
      <div class="project-stack">
        {stack.map((tech) => <TechTag tech={tech} />)}
      </div>
      <div class="project-links">
        {githubUrl && (
          <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="project-link">
            <svg viewBox="0 0 24 24" fill="currentColor" class="link-icon">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            Ver código
          </a>
        )}
        {demoUrl && (
          <a href={demoUrl} target="_blank" rel="noopener noreferrer" class="project-link primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="link-icon">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15,3 21,3 21,9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
            Demo en vivo
          </a>
        )}
      </div>
    </header>

    <div class="prose prose-lg max-w-none prose-headings:font-display prose-a:font-medium prose-a:underline prose-a:underline-offset-2 prose-pre:rounded-lg prose-img:rounded-lg animate-fade-up animate-delay-1">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .project-detail {
    padding: 2rem 1.5rem 4rem;
  }

  .project-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .project-dates {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .project-title {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .project-description {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: all 200ms ease;
  }

  .project-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .project-link.primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .project-link.primary:hover {
    background: var(--color-accent-hover);
  }

  .link-icon {
    width: 1rem;
    height: 1rem;
  }

  @media (max-width: 640px) {
    .project-title {
      font-size: 1.75rem;
    }
  }
</style>
