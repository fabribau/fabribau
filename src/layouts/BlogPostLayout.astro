---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '../components/blog/TagBadge.astro';
import ShareButtons from '../components/blog/ShareButtons.astro';
import { formatDate, getReadingTime } from '../lib/content';
import { ui } from '../i18n/es/ui';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  content: string;
  slug: string;
}

const { title, description, pubDate, updatedDate, tags, content, slug } = Astro.props;
const readingTime = getReadingTime(content);
const url = Astro.url.href;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  publishedTime={pubDate.toISOString()}
  tags={tags}
>
  <article class="blog-post container-prose">
    <header class="post-header animate-fade-up">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span class="separator">·</span>
        <span>{readingTime} {ui.blog.readingTime}</span>
      </div>
      <h1 class="post-title">{title}</h1>
      {updatedDate && (
        <p class="post-updated">
          Actualizado: <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
        </p>
      )}
      <div class="post-tags">
        {tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
    </header>

    <div class="prose prose-lg max-w-none prose-headings:font-display prose-a:font-medium prose-a:underline prose-a:underline-offset-2 prose-pre:rounded-lg prose-img:rounded-lg animate-fade-up animate-delay-1">
      <slot />
    </div>

    <footer class="post-footer animate-fade-up animate-delay-2">
      <!-- Like button -->
      <div class="like-section">
        <button id="like-btn" class="like-btn" data-slug={slug} aria-label="Dar like">
          <svg class="like-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          <span id="like-count">0</span>
        </button>
      </div>

      <ShareButtons title={title} url={url} />

      <!-- Newsletter CTA -->
      <div class="newsletter-section">
        <h3>{ui.blog.subscribe}</h3>
        <p>{ui.blog.subscribeDesc}</p>
        <form id="newsletter-form" class="newsletter-form">
          <input
            type="email"
            name="email"
            placeholder="tu@email.com"
            required
            class="newsletter-input"
          />
          <button type="submit" class="newsletter-btn">Suscribirme</button>
        </form>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: 2rem 1.5rem 4rem;
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .separator {
    color: var(--color-border);
  }

  .post-title {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .post-updated {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .like-section {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .like-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    background: var(--color-surface);
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: all 200ms ease;
  }

  .like-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .like-btn.liked {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .like-btn.liked .like-icon {
    fill: var(--color-accent);
  }

  .like-icon {
    width: 1.125rem;
    height: 1.125rem;
  }

  .newsletter-section {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-align: center;
  }

  .newsletter-section h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .newsletter-section p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    max-width: 400px;
    margin: 0 auto;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.625rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.9375rem;
  }

  .newsletter-input:focus {
    border-color: var(--color-accent);
    outline: none;
  }

  .newsletter-btn {
    padding: 0.625rem 1.25rem;
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: 0.375rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 200ms ease;
  }

  .newsletter-btn:hover {
    background: var(--color-accent-hover);
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 1.75rem;
    }

    .newsletter-form {
      flex-direction: column;
    }
  }
</style>

<script>
  // Like button logic
  const likeBtn = document.getElementById('like-btn') as HTMLButtonElement;
  const likeCount = document.getElementById('like-count');
  const slug = likeBtn?.dataset.slug;

  if (likeBtn && likeCount && slug) {
    // Check if already liked
    const likedSlugs = JSON.parse(localStorage.getItem('likedSlugs') || '[]');
    if (likedSlugs.includes(slug)) {
      likeBtn.classList.add('liked');
    }

    likeBtn.addEventListener('click', async () => {
      if (likedSlugs.includes(slug)) return;

      try {
        const res = await fetch('/api/likes', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug }),
        });
        const data = await res.json();
        likeCount.textContent = String(data.count);
        likeBtn.classList.add('liked');
        likedSlugs.push(slug);
        localStorage.setItem('likedSlugs', JSON.stringify(likedSlugs));
      } catch (e) {
        // Silently fail — offline or API not ready
      }
    });

    // Load initial count
    fetch(`/api/likes?slug=${slug}`)
      .then(res => res.json())
      .then(data => { likeCount.textContent = String(data.count); })
      .catch(() => {}); // Silently fail
  }

  // Newsletter form
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = new FormData(form).get('email') as string;
    try {
      await fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      form.innerHTML = '<p style="color: var(--color-accent);">¡Gracias por suscribirte! 🎉</p>';
    } catch (e) {
      // Silently fail
    }
  });
</script>
