---
import TagBadge from './TagBadge.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { formatDate, getReadingTime } from '../../lib/content';
import { ui } from '../../i18n/es/ui';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  body: string;
  featured?: boolean;
  coverImage?: ImageMetadata;
}

const { title, description, pubDate, tags, slug, body, featured = false, coverImage } = Astro.props;
const readingTime = getReadingTime(body);
const visibleTags = tags.slice(0, 3);
---

<article class="post-card" id={`post-${slug}`}>
  <a href={`/blog/${slug}`} class="card-link" aria-label={`Leer el post: ${title}`}></a>
  {featured && <span class="featured-badge">⭐ Destacado</span>}

  <div class="card-thumbnail">
    {coverImage
      ? <Image src={coverImage} alt={`Imagen de portada: ${title}`} class="card-thumbnail-img" loading="lazy" decoding="async" width={640} />
      : <div class="card-thumbnail-placeholder" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </div>
    }
  </div>

  <div class="card-content">
    <div class="card-meta">
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
      <span class="separator">·</span>
      <span>{readingTime} {ui.blog.readingTime}</span>
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
    <div class="card-footer">
      <div class="card-tags">
        {visibleTags.map((tag) => <TagBadge tag={tag} />)}
      </div>
    </div>
  </div>
</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: all 200ms ease;
    position: relative;
    overflow: hidden;
  }

  .card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
  }

  .card-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .post-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
  }

  /* ---- Thumbnail ---- */
  .card-thumbnail {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-surface-alt, #1a1a2e);
  }

  .card-thumbnail-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 300ms ease;
  }

  .post-card:hover .card-thumbnail-img {
    transform: scale(1.04);
  }

  .card-thumbnail-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg,
      var(--color-surface-alt, #111118) 0%,
      color-mix(in srgb, var(--color-accent) 12%, var(--color-surface, #18181b)) 100%
    );
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  /* ---- Badge ---- */
  .featured-badge {
    position: absolute;
    top: 0.625rem;
    right: 0.625rem;
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border-radius: 2rem;
    font-weight: 500;
    z-index: 2;
    pointer-events: none;
  }

  /* ---- Content ---- */
  .card-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    padding: 1.25rem 1.25rem 1rem;
    position: relative;
    z-index: 2;
    pointer-events: none;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .separator {
    color: var(--color-border);
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-text);
    margin: 0;
    transition: color 200ms ease;
  }

  .post-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    margin-top: auto;
    padding-top: 0.875rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    position: relative;
    z-index: 3;
    pointer-events: auto;
  }
</style>
