---
interface Props {
  status: 'completed' | 'in-progress' | 'archived';
}

const { status } = Astro.props;

const statusConfig = {
  'completed': { label: 'Terminado', emoji: '🟢', class: 'completed' },
  'in-progress': { label: 'En desarrollo', emoji: '🟡', class: 'in-progress' },
  'archived': { label: 'Archivado', emoji: '⚫', class: 'archived' },
};

const config = statusConfig[status];
---

<span class:list={['status-badge', config.class]}>
  <span class="emoji">{config.emoji}</span>
  {config.label}
</span>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.2rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: 2rem;
    line-height: 1.4;
  }

  .completed {
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }

  .in-progress {
    color: #eab308;
    background: rgba(234, 179, 8, 0.1);
  }

  .archived {
    color: var(--color-text-muted);
    background: var(--color-surface-alt);
  }

  .emoji {
    font-size: 0.625rem;
  }
</style>
