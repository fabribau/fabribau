---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/blog/PostCard.astro";
import TagBadge from "../../components/blog/TagBadge.astro";
import { getPublishedPosts, getAllTags } from "../../lib/content";
import { ui } from "../../i18n/es/ui";

const posts = await getPublishedPosts();
const tags = await getAllTags();
---

<BaseLayout title={ui.blog.title} description={ui.blog.description}>
  <section class="blog-page container-wide">
    <header class="page-header animate-fade-up">
      <h1 class="page-title">{ui.blog.title}</h1>
      <p class="page-description">{ui.blog.description}</p>
    </header>

    <!-- Tag filter -->
    <div class="tag-filter animate-fade-up animate-delay-1">
      <a href="/blog" class="filter-tag active" data-tag="all"
        >{ui.blog.allTags}</a
      >
      {
        tags.map((tag) => (
          <a
            href={`/blog?tag=${encodeURIComponent(tag)}`}
            class="filter-tag"
            data-tag={tag}
          >
            {tag}
          </a>
        ))
      }
    </div>

    <!-- Posts grid -->
    {
      posts.length > 0 ? (
        <div class="posts-grid animate-fade-up animate-delay-2">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.slug}
              body={post.body || ""}
              featured={post.data.featured}
              coverImage={post.data.coverImage}
            />
          ))}
        </div>
      ) : (
        <p class="no-posts">{ui.blog.noPosts}</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .blog-page {
    padding: 2rem 1.5rem 4rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: 2.25rem;
    margin-bottom: 0.5rem;
  }

  .page-description {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    max-width: 600px;
  }

  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .filter-tag {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    text-decoration: none;
    transition: all 200ms ease;
    cursor: pointer;
  }

  .filter-tag:hover,
  .filter-tag.active {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .no-posts {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.0625rem;
    padding: 3rem 0;
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Client-side tag filtering
  const filterTags = document.querySelectorAll(".filter-tag");
  const postCards = document.querySelectorAll(".post-card");

  // Check URL for tag parameter
  const urlParams = new URLSearchParams(window.location.search);
  const activeTag = urlParams.get("tag");

  if (activeTag) {
    filterTags.forEach((tag) => {
      tag.classList.remove("active");
      if (tag.getAttribute("data-tag") === activeTag) {
        tag.classList.add("active");
      }
    });
  }

  filterTags.forEach((tag) => {
    tag.addEventListener("click", (e) => {
      e.preventDefault();
      const selectedTag = tag.getAttribute("data-tag");

      filterTags.forEach((t) => t.classList.remove("active"));
      tag.classList.add("active");

      postCards.forEach((card) => {
        if (selectedTag === "all") {
          (card as HTMLElement).style.display = "";
        } else {
          // Check if card contains the tag
          const cardTags = card.querySelectorAll(".tag-badge");
          const hasTag = Array.from(cardTags).some(
            (t) => t.textContent?.trim() === selectedTag,
          );
          (card as HTMLElement).style.display = hasTag ? "" : "none";
        }
      });

      // Update URL without reload
      const url = new URL(window.location.href);
      if (selectedTag === "all") {
        url.searchParams.delete("tag");
      } else {
        url.searchParams.set("tag", selectedTag!);
      }
      window.history.replaceState({}, "", url);
    });
  });
</script>
