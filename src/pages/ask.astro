---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ui } from '../i18n/es/ui';
---

<BaseLayout title={ui.ask.title} description={ui.ask.description}>
  <section class="ask-page container-prose">
    <header class="page-header animate-fade-up">
      <h1 class="page-title">{ui.ask.title}</h1>
      <p class="page-description">{ui.ask.intro}</p>
    </header>

    <div class="ask-container animate-fade-up animate-delay-1">
      <!-- Question counter -->
      <div class="question-counter">
        <span class="counter-label">{ui.ask.remaining}:</span>
        <div class="counter-dots">
          <span class="dot active" data-index="0"></span>
          <span class="dot active" data-index="1"></span>
          <span class="dot active" data-index="2"></span>
          <span class="dot active" data-index="3"></span>
          <span class="dot active" data-index="4"></span>
        </div>
        <span id="counter-text" class="counter-text">5/5</span>
      </div>

      <!-- Chat area -->
      <div id="chat-area" class="chat-area">
        <div class="chat-welcome">
          <div class="welcome-avatar">
            <span>FR</span>
          </div>
          <p>¡Hola! Soy una IA entrenada con información sobre Fabrizio. Preguntame lo que quieras sobre su experiencia, proyectos, habilidades o intereses.</p>
        </div>
      </div>

      <!-- Input area -->
      <form id="ask-form" class="ask-form">
        <input
          type="text"
          id="ask-input"
          name="question"
          placeholder={ui.ask.placeholder}
          required
          autocomplete="off"
          class="ask-input"
        />
        <button type="submit" id="ask-btn" class="ask-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="send-icon">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22,2 15,22 11,13 2,9"></polygon>
          </svg>
        </button>
      </form>

      <!-- Exhausted message -->
      <p id="exhausted-msg" class="exhausted-msg" style="display: none;">
        {ui.ask.exhausted}
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .ask-page {
    padding: 2rem 1.5rem 4rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .page-description {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .ask-container {
    max-width: 700px;
    margin: 0 auto;
  }

  /* Counter */
  .question-counter {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .counter-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .counter-dots {
    display: flex;
    gap: 0.375rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
    transition: background 200ms ease;
  }

  .dot.active {
    background: var(--color-accent);
  }

  .counter-text {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-left: auto;
  }

  /* Chat */
  .chat-area {
    min-height: 300px;
    max-height: 500px;
    overflow-y: auto;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .chat-welcome {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .welcome-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .chat-welcome p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Messages */
  :global(.chat-message) {
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 85%;
  }

  :global(.chat-message.user) {
    background: var(--color-accent);
    color: white;
    align-self: flex-end;
    border-bottom-right-radius: 0.125rem;
  }

  :global(.chat-message.assistant) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    align-self: flex-start;
    border-bottom-left-radius: 0.125rem;
  }

  :global(.chat-message.thinking) {
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Input */
  .ask-form {
    display: flex;
    gap: 0.5rem;
  }

  .ask-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.9375rem;
    font-family: var(--font-body);
  }

  .ask-input:focus {
    border-color: var(--color-accent);
    outline: none;
  }

  .ask-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: auto;
    background: var(--color-accent);
    border: none;
    border-radius: 0.375rem;
    color: white;
    cursor: pointer;
    transition: background 200ms ease;
  }

  .ask-btn:hover {
    background: var(--color-accent-hover);
  }

  .ask-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .send-icon {
    width: 1.125rem;
    height: 1.125rem;
  }

  .exhausted-msg {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    padding: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    margin-top: 1rem;
  }
</style>

<script>
  const form = document.getElementById('ask-form') as HTMLFormElement;
  const input = document.getElementById('ask-input') as HTMLInputElement;
  const btn = document.getElementById('ask-btn') as HTMLButtonElement;
  const chatArea = document.getElementById('chat-area') as HTMLDivElement;
  const counterText = document.getElementById('counter-text') as HTMLSpanElement;
  const exhaustedMsg = document.getElementById('exhausted-msg') as HTMLParagraphElement;
  const dots = document.querySelectorAll('.dot');

  let questionsUsed = parseInt(sessionStorage.getItem('askQuestionsUsed') || '0');
  const MAX_QUESTIONS = 5;
  const history: { role: string; content: string }[] = [];

  function updateCounter() {
    const remaining = MAX_QUESTIONS - questionsUsed;
    counterText.textContent = `${remaining}/${MAX_QUESTIONS}`;

    dots.forEach((dot, i) => {
      if (i < remaining) {
        dot.classList.add('active');
      } else {
        dot.classList.remove('active');
      }
    });

    if (remaining <= 0) {
      form.style.display = 'none';
      exhaustedMsg.style.display = 'block';
    }
  }

  function addMessage(content: string, role: 'user' | 'assistant' | 'thinking') {
    const msg = document.createElement('div');
    msg.className = `chat-message ${role}`;
    msg.textContent = content;
    chatArea.appendChild(msg);
    chatArea.scrollTop = chatArea.scrollHeight;
    return msg;
  }

  updateCounter();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const question = input.value.trim();
    if (!question || questionsUsed >= MAX_QUESTIONS) return;

    // Add user message
    addMessage(question, 'user');
    input.value = '';
    btn.disabled = true;

    // Increment counter
    questionsUsed++;
    sessionStorage.setItem('askQuestionsUsed', String(questionsUsed));
    updateCounter();

    // Add thinking indicator
    const thinkingMsg = addMessage('Pensando...', 'thinking');

    // Add to history
    history.push({ role: 'user', content: question });

    try {
      const res = await fetch('/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question, history }),
      });

      const data = await res.json();
      thinkingMsg.remove();

      const answer = data.answer || 'No pude generar una respuesta. Intentá de nuevo.';
      addMessage(answer, 'assistant');
      history.push({ role: 'assistant', content: answer });
    } catch {
      thinkingMsg.remove();
      addMessage('Hubo un error. Intentá de nuevo.', 'assistant');
    } finally {
      btn.disabled = false;
      input.focus();
    }
  });
</script>
