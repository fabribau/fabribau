---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { PUBLIC_TURNSTILE_SITE_KEY } from "astro:env/client";
import { ui } from "../i18n/es/ui";

const resolvedTurnstileSiteKey = PUBLIC_TURNSTILE_SITE_KEY;
---

<BaseLayout title={ui.contact.title} description={ui.contact.description}>
  <section class="contact-page container-prose">
    <header class="page-header animate-fade-up">
      <h1 class="page-title">{ui.contact.title}</h1>
      <p class="page-description">{ui.contact.intro}</p>
    </header>

    <div class="contact-grid animate-fade-up animate-delay-1">
      <!-- Contact Form -->
      <form
        id="contact-form"
        class="contact-form"
        data-send-text={ui.contact.send}
        data-sending-text={ui.contact.sending}
        data-success-text={ui.contact.success}
        data-error-text={ui.contact.error}
        data-required-error-text={ui.contact.requiredError}
        data-invalid-email-error-text={ui.contact.invalidEmailError}
        data-message-max-error-text={ui.contact.messageMaxError}
      >
        <div class="form-group">
          <label for="name" class="form-label">{ui.contact.nameLabel}</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            maxlength="120"
            class="form-input"
          />
        </div>
        <div class="form-group">
          <label for="email" class="form-label">{ui.contact.emailLabel}</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            maxlength="320"
            class="form-input"
          />
        </div>
        <div class="form-group">
          <label for="subject" class="form-label"
            >{ui.contact.subjectLabel}</label
          >
          <input
            type="text"
            id="subject"
            name="subject"
            required
            maxlength="150"
            class="form-input"
          />
        </div>
        <div class="form-group">
          <label for="message" class="form-label"
            >{ui.contact.messageLabel}</label
          >
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            maxlength="1000"
            class="form-textarea"
            aria-describedby="char-counter"></textarea>
          <p id="char-counter" class="char-counter" aria-live="polite">
            0/1000
          </p>
        </div>

        <!-- Honeypot: invisible for humans, bots fill it in -->
        <div class="hp-field" aria-hidden="true">
          <label for="website">Website</label>
          <input
            type="text"
            id="website"
            name="website"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <!-- Cloudflare Turnstile widget -->
        <div
          class="cf-turnstile"
          data-sitekey={resolvedTurnstileSiteKey}
          data-theme="auto"
        >
        </div>

        <button type="submit" id="submit-btn" class="submit-btn"
          >{ui.contact.send}</button
        >
        <p id="form-status" class="form-status" aria-live="polite"></p>
      </form>

      <!-- Social Links -->
      <aside class="contact-aside">
        <h2 class="aside-title">También me encontrás en</h2>
        <div class="social-links">
          <a
            href="https://wa.me/5492664024353?text=Hola%20Fabrizio%2C%20vi%20tu%20sitio%20y%20quiero%20consultarte%20por%20un%20proyecto."
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="social-icon">
              <path
                d="M17.6 6.32A8.7 8.7 0 0 0 12 4.2a8.8 8.8 0 0 0-7.64 13.2L3 21l3.75-1.23A8.8 8.8 0 0 0 12 21a8.8 8.8 0 0 0 8.8-8.8 8.7 8.7 0 0 0-3.2-5.88Zm-5.6 13.2a7.3 7.3 0 0 1-3.72-1.02l-.27-.16-2.22.72.73-2.16-.18-.28a7.35 7.35 0 1 1 5.66 2.9Zm4.03-5.5c-.22-.11-1.31-.64-1.52-.71-.2-.08-.34-.11-.49.11-.14.22-.56.7-.68.85-.13.15-.25.17-.47.06-.22-.11-.92-.34-1.75-1.1-.65-.58-1.1-1.3-1.22-1.51-.13-.22-.01-.34.1-.45.1-.1.22-.25.33-.38.1-.13.14-.22.21-.36.08-.15.04-.28-.02-.4-.06-.11-.49-1.19-.67-1.63-.18-.43-.36-.38-.49-.39h-.42c-.14 0-.37.06-.57.28-.2.22-.75.73-.75 1.79s.77 2.08.88 2.23c.11.15 1.5 2.29 3.64 3.21.51.22.9.35 1.2.44.5.16.96.14 1.32.08.4-.06 1.31-.54 1.49-1.06.18-.52.18-.96.13-1.06-.06-.1-.2-.15-.42-.26Z"
              ></path>
            </svg>
            <div>
              <span class="social-name">WhatsApp</span>
              <span class="social-handle">+54 9 2664 024353</span>
            </div>
          </a>
          <a
            href="mailto:fabriziojriera@gmail.com"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="social-icon"
            >
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22,7-8.97,5.7a1.94,1.94,0,0,1-2.06,0L2,7"></path>
            </svg>
            <div>
              <span class="social-name">Email</span>
              <span class="social-handle">fabriziojriera@gmail.com</span>
            </div>
          </a>
          <a
            href="https://linkedin.com/in/fabrizio-bauer"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="social-icon">
              <path
                d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"
              ></path>
            </svg>
            <div>
              <span class="social-name">LinkedIn</span>
              <span class="social-handle">fabrizio-bauer</span>
            </div>
          </a>
          <a
            href="https://github.com/fabribau"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="social-icon">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            <div>
              <span class="social-name">GitHub</span>
              <span class="social-handle">@fabribau</span>
            </div>
          </a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<!-- Cloudflare Turnstile script (loaded async, non-blocking) -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer
></script>

<style>
  .contact-page {
    padding: 2rem 1.5rem 4rem;
    max-width: 900px;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .page-description {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem;
    align-items: flex-start;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .form-input,
  .form-textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.9375rem;
    font-family: var(--font-body);
    transition: border-color 200ms ease;
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--color-accent);
    outline: none;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* Honeypot - visually hidden but not display:none so bots detect it as real */
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }

  .submit-btn {
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: 0.375rem;
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    transition: all 200ms ease;
    align-self: flex-start;
  }

  .submit-btn:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .form-status {
    font-size: 0.875rem;
    margin: 0;
  }

  .char-counter {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-align: right;
  }

  .char-counter.limit {
    color: #f59e0b;
  }

  .form-status.success {
    color: #22c55e;
  }

  .form-status.error {
    color: #ef4444;
  }

  /* Social links */
  .aside-title {
    font-size: 1.125rem;
    margin-bottom: 1.25rem;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: all 200ms ease;
  }

  .social-link:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .social-icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  .social-name {
    display: block;
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .social-handle {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>

<script>
  import { actions, isInputError } from "astro:actions";

  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const statusMsg = document.getElementById(
    "form-status",
  ) as HTMLParagraphElement;
  const messageField = document.getElementById(
    "message",
  ) as HTMLTextAreaElement;
  const charCounter = document.getElementById(
    "char-counter",
  ) as HTMLParagraphElement;
  const MAX_MESSAGE_LENGTH = 1000;

  const sendText = form?.dataset.sendText ?? "Enviar mensaje";
  const sendingText = form?.dataset.sendingText ?? "Enviando...";
  const successText =
    form?.dataset.successText ?? "¡Mensaje enviado! Te respondo pronto.";
  const errorText =
    form?.dataset.errorText ?? "Hubo un error al enviar. Intentá de nuevo.";

  const setStatus = (message: string, type: "success" | "error") => {
    statusMsg.textContent = message;
    statusMsg.className = "form-status";
    statusMsg.classList.add(type);
  };

  const updateCharCounter = () => {
    const length = messageField?.value.length ?? 0;
    charCounter.textContent = `${length}/${MAX_MESSAGE_LENGTH}`;
    charCounter.classList.toggle("limit", length >= MAX_MESSAGE_LENGTH);
  };

  updateCharCounter();
  messageField?.addEventListener("input", updateCharCounter);

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.textContent = sendingText;
    statusMsg.textContent = "";
    statusMsg.className = "form-status";

    const formData = new FormData(form);

    // The Turnstile widget injects a hidden input[name="cf-turnstile-response"] automatically
    // FormData already captures it since it's inside the <form>

    try {
      const { data, error } = await actions.contact(formData);

      if (error) {
        if (isInputError(error)) {
          const firstErrorMsg = Object.values(error.fields)[0]?.[0];
          setStatus(firstErrorMsg ?? errorText, "error");
        } else {
          setStatus(error.message || errorText, "error");
        }
      } else {
        setStatus(successText, "success");
        form.reset();
        updateCharCounter();
        // Reset Turnstile widget for a new submission
        if (typeof (window as any).turnstile !== "undefined") {
          (window as any).turnstile.reset();
        }
      }
    } catch {
      setStatus(errorText, "error");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = sendText;
    }
  });
</script>
